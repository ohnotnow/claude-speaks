{
  "llm_model": "mistral/mistral-small-latest",
  "tts_provider": "mistral",
  "features": {
    "monologue": true,
    "main": true,
    "notification": true
  },
  "notification_languages": [
    ["English", 1],
    ["German (Deutsch)", 5],
    ["Japanese (日本語)", 5],
    ["Chinese (Simplified)", 5],
    ["Hindi", 5],
    ["Korean", 5],
    ["Vietnamese", 5]
  ],
  "voices": {
    "mistral": {
      "main": {"voice": "gb_jane"},
      "monologue": {"voice": "fr_marie_sad"},
      "notification": {"voice": "fr_marie_sad"}
    },
    "xai": {
      "main": {"voice": "Eve", "language": "en"},
      "monologue": {"voice": "Ara", "language": "fr"},
      "notification": {"voice": "Ara", "language": "ja"}
    },
    "elevenlabs": {
      "main": {"voice": "6qpxBH5KUSDb40bij36w"},
      "monologue": {"voice": "6qpxBH5KUSDb40bij36w"},
      "notification": {"voice": "6qpxBH5KUSDb40bij36w"}
    },
    "openai": {
      "main": {"voice": "coral", "instructions": "Speak clearly and naturally, in a calm measured tone."},
      "monologue": {"voice": "ash", "instructions": "Speak in the voice of Marvin the Paranoid Android: weary, deadpan, drained of enthusiasm."},
      "notification": {"voice": "ash", "instructions": "Speak in the voice of Marvin the Paranoid Android: weary, deadpan, drained of enthusiasm."}
    }
  },
  "provider_settings": {
    "_note": "Per-provider knobs. Each provider reads its own slice via self.settings; omit the block entirely to use built-in defaults. xAI's sample_rate / bit_rate and ElevenLabs' output_format must produce audio at the same rate as the gap mp3s in gaps/ — mismatched rates silently truncate clip 2 onward.",
    "xai": {
      "sample_rate": 22050,
      "bit_rate": 64000
    },
    "elevenlabs": {
      "model_id": "eleven_v3",
      "output_format": "mp3_22050_32"
    },
    "openai": {
      "model": "gpt-4o-mini-tts",
      "sample_rate": 22050,
      "bit_rate": 56000
    }
  },
  "gap_file": "0_75s",
  "word_replacements": {
    "vite": "veet",
    "nginx": "engine-ex",
    "kubectl": "cube-control",
    "kubernetes": "koo-ber-net-eez",
    "postgres": "post-gress",
    ".env": "dot-env",
    "sqlite": "sequel-lite"
  }
}
